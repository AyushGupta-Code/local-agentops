# Application runtime
APP_NAME=Local AgentOps
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_DEBUG=true

# Local data directories
DATA_ROOT=./data
RAW_DATA_DIR=raw
PROCESSED_DATA_DIR=processed
INDEX_DATA_DIR=indexes
EVAL_DATA_DIR=eval

# Local model configuration
LOCAL_LLM_PROVIDER=ollama
LOCAL_LLM_MODEL=llama3.1
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_TIMEOUT_SECONDS=60
LOCAL_EMBEDDING_MODEL=bge-small-en-v1.5

# Retrieval defaults
DEFAULT_TOP_K=5
DEFAULT_CHUNK_SIZE=800
DEFAULT_CHUNK_OVERLAP=120
MAX_CONTEXT_CHUNKS=12
CITATION_CHARACTER_LIMIT=280
